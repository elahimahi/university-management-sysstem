RewriteEngine On

# Allow direct access to PHP files and actual directories - no rewrite needed
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*)$ - [L]

# Everything else (routes without .php extension) goes through index.php
# This allows clean REST API URLs like /faculty/stats instead of /faculty/stats.php
RewriteRule ^(.*)$ /Database_Project/university-management-sysstem/backend/index.php [QSA,L]
