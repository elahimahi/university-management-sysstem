# Environment Variables Template
# Copy this file to .env.local and update with your values
# .env.local is gitignored and should contain your local configuration

# API Configuration
REACT_APP_API_BASE_URL=http://localhost/Database_Project/Database-main/Database-main/backend
REACT_APP_API_TIMEOUT=30000

# Environment
REACT_APP_ENV=development

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG=true

# Application Configuration
REACT_APP_NAME=University Management System
REACT_APP_VERSION=1.0.0
