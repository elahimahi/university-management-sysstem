# University Management System - Environment Configuration Example
# Copy this to .env and replace values with your actual configuration

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=mssql
DB_USER=sa
DB_PASSWORD=P@ssw0rd123
DB_NAME=university_db
DB_PORT=1433

# ============================================
# APPLICATION CONFIGURATION
# ============================================
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000
REACT_APP_ENV=development
REACT_APP_NAME=University Management System
REACT_APP_VERSION=1.0.0
REACT_APP_ENABLE_DEBUG=true

# ============================================
# PAYMENT GATEWAY
# ============================================
PAYMENT_GATEWAY=ssl_commerz
PAYMENT_API_KEY=your_api_key_here
PAYMENT_API_SECRET=your_api_secret_here
PAYMENT_STORE_ID=your_store_id_here

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_jwt_secret_change_in_production
TOKEN_EXPIRY=3600

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ============================================
# SMTP/EMAIL CONFIGURATION (Optional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENABLED=false

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_API_KEY=your_sms_api_key

# ============================================
# DOCKER CONFIGURATION
# ============================================
DOCKER_NETWORK=university_network
COMPOSE_PROJECT_NAME=university_system
